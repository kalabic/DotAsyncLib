<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>DotAsync</RootNamespace>
    <Version>1.3.1-beta</Version>
    <Authors>silvije</Authors>
    <Copyright>Copyright © Silvije Kalabic 2025, 2026 All rights reserved.</Copyright>
    <PackageProjectUrl>https://github.com/kalabic/DotAsyncLib</PackageProjectUrl>
    <RepositoryUrl>https://github.com/kalabic/DotAsyncLib</RepositoryUrl>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <AssemblyName>DotAsync</AssemblyName>
  </PropertyGroup>

  <ItemGroup>
    <None Include="..\..\doc\package\README.md">
      <Pack>True</Pack>
      <PackagePath>\</PackagePath>
    </None>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="DotBase" Version="1.3.1-beta" />
  </ItemGroup>

</Project>
